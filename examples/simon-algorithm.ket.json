{
  "ket_version": "0.1.0",
  "name": "Simon's Algorithm (4-Qubit)",
  "description": "Finds a hidden string s with O(n) queries, exponentially faster than classical O(2^n). This simplified version demonstrates the core quantum circuit structure.",
  "qubits": 4,
  "gates": [
    { "type": "H", "targets": [0], "column": 0 },
    { "type": "H", "targets": [1], "column": 0 },
    { "type": "CNOT", "controls": [0], "targets": [2], "column": 1 },
    { "type": "CNOT", "controls": [1], "targets": [3], "column": 1 },
    { "type": "H", "targets": [0], "column": 2 },
    { "type": "H", "targets": [1], "column": 2 }
  ],
  "measurements": [
    { "qubit": 0, "column": 3 },
    { "qubit": 1, "column": 3 }
  ]
}
