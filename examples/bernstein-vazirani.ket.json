{
  "ket_version": "0.1.0",
  "name": "Bernstein-Vazirani Algorithm",
  "description": "Recovers a hidden string s in a single query. Classically requires n queries. This example finds the hidden string 101 (5 in decimal).",
  "qubits": 4,
  "gates": [
    { "type": "X", "targets": [3], "column": 0 },
    { "type": "H", "targets": [0], "column": 1 },
    { "type": "H", "targets": [1], "column": 1 },
    { "type": "H", "targets": [2], "column": 1 },
    { "type": "H", "targets": [3], "column": 1 },
    { "type": "CNOT", "controls": [0], "targets": [3], "column": 2 },
    { "type": "CNOT", "controls": [2], "targets": [3], "column": 3 },
    { "type": "H", "targets": [0], "column": 4 },
    { "type": "H", "targets": [1], "column": 4 },
    { "type": "H", "targets": [2], "column": 4 }
  ],
  "measurements": [
    { "qubit": 0, "column": 5 },
    { "qubit": 1, "column": 5 },
    { "qubit": 2, "column": 5 }
  ]
}
